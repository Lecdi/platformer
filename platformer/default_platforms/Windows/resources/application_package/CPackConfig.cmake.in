set(CPACK_GENERATOR "NSIS")
@PLATFORM_CPACK_CONFIG_NSIS_CODE@

@cpack_install_code@

set(CPACK_CMAKE_GENERATOR "@CMAKE_GENERATOR@")

@components_code@

set(CPACK_PACKAGE_FILE_NAME "@P_PACKAGE_FILE_NAME@")

@license_code@

@mui_icon_code@
@mui_unicon_code@
@installed_icon_code@

set(CPACK_PACKAGE_DIRECTORY "@P_OUTPUT_DIR@")

set(CPACK_PACKAGE_NAME "@name@")

set(CPACK_NSIS_DISPLAY_NAME "@P_DISPLAY_NAME@")
set(CPACK_NSIS_PACKAGE_NAME "@P_DISPLAY_NAME@")

@vendor_code@

set(CPACK_PACKAGE_VERSION "@P_VERSION_STRING@")

set(CPACK_PACKAGE_DESCRIPTION "@P_DESCRIPTION@")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "@P_DESCRIPTION@")

set(CPACK_PACKAGE_INSTALL_DIRECTORY "@name@")

set(CPACK_NSIS_ENABLE_UNINSTALL_BEFORE_INSTALL ON)
