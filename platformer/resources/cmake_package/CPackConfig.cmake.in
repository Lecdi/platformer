set(CPACK_GENERATOR "ZIP")

@cpack_install_code@

set(CPACK_CMAKE_GENERATOR "@CMAKE_GENERATOR@")

@components_code@

set(CPACK_PACKAGE_FILE_NAME "@P_PACKAGE_FILE_NAME@")

set(CPACK_PACKAGE_DIRECTORY "@P_OUTPUT_DIR@")

set(CPACK_PACKAGE_NAME "@name@")

set(CPACK_PACKAGE_VERSION "@P_VERSION_STRING@")

set(CPACK_PACKAGE_DESCRIPTION "@P_DESCRIPTION@")
set(CPACK_PACKAGE_DESCRIPTION_SUMMARY "@P_DESCRIPTION@")
